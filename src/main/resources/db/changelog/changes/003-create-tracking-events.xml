<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003" author="kikidilivery">
        <createTable tableName="tracking_events">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="shipment_id" type="UUID">
                <constraints foreignKeyName="fk_tracking_shipment" references="shipments(id)" deleteCascade="true"/>
            </column>
            <column name="location" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="event_time" type="TIMESTAMPTZ"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
