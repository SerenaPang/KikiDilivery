<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002" author="kikidilivery">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="shipments" />
            </not>
        </preConditions>
        <createTable tableName="shipments">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="sender_id" type="UUID">
                <constraints foreignKeyName="fk_shipments_sender" references="users(id)" />
            </column>
            <column name="receiver_id" type="UUID">
                <constraints foreignKeyName="fk_shipments_receiver" references="users(id)" />
            </column>
            <column name="pickup_address" type="VARCHAR(255)" />
            <column name="delivery_address" type="VARCHAR(255)" />
            <column name="status" type="VARCHAR(50)" />
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="now()" />
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="now()" />
        </createTable>
    </changeSet>

</databaseChangeLog>